# server.env — intentional errors for MCP validation testing
# Expected: 4 diagnostics

# ERROR: invalid value (valid values are: SIMPLE, JSON, TBASIC)
WLP_LOGGING_CONSOLE_FORMAT=badvalue

# ERROR: case-sensitive value (must be lowercase: message, trace, accessLog, ffdc, audit)
WLP_LOGGING_CONSOLE_SOURCE=Message

# ERROR: out-of-range port (valid range: 1..65535)
WLP_DEBUG_ADDRESS=99999

# WARNING: empty value
WLP_DEBUG_SUSPEND=

# OK: valid entry
WLP_LOGGING_CONSOLE_LOGLEVEL=INFO
