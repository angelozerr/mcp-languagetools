{
  "id": "codelldb-installer",
  "name": "CodeLLDB",
  "check": {
    "fileExists": {
      "name": "Check if CodeLLDB is installed",
      "file": {
        "windows": "$SERVER_HOME$/extension/adapter/codelldb.exe",
        "default": "$SERVER_HOME$/extension/adapter/codelldb"
      }
    }
  },
  "run": {
    "download": {
      "name": "Download CodeLLDB",
      "github": {
        "owner": "vadimcn",
        "repository": "codelldb",
        "prerelease": false,
        "asset": {
          "windows": "codelldb-win32-x64.vsix",
          "unix": {
            "x86_64": "codelldb-linux-x64.vsix",
            "arm64": "codelldb-linux-arm64.vsix"
          },
          "mac": {
            "x86_64": "codelldb-darwin-x64.vsix",
            "arm64": "codelldb-darwin-arm64.vsix"
          }
        }
      },
      "output": {
        "dir": "$SERVER_HOME$",
        "file": {
          "name": {
            "windows": "extension/adapter/codelldb.exe",
            "default": "extension/adapter/codelldb"
          },
          "executable": true
        }
      },
      "onSuccess": {
        "configureServer": {
          "name": "Configure CodeLLDB server command",
          "command": {
            "windows": "$SERVER_HOME$/extension/adapter/codelldb.exe",
            "default": "$SERVER_HOME$/extension/adapter/codelldb"
          }
        }
      }
    }
  }
}
