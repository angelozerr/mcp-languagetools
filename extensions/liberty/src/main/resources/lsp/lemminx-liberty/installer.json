{
  "id": "lemminx-liberty",
  "name": "LemMinX Liberty Extension",
  "check": {
    "fileExists": {
      "name": "Check if LemMinX Liberty plugin is installed",
      "file": "$SERVER_HOME$/lib/liberty-langserver-lemminx.jar"
    }
  },
  "run": {
    "download": {
      "name": "Download LemMinX Liberty plugin",
      "url": "https://repo1.maven.org/maven2/io/openliberty/tools/liberty-langserver-lemminx/2.4/liberty-langserver-lemminx-2.4-jar-with-dependencies.jar",
      "output": {
        "dir": "$SERVER_HOME$/lib",
        "file": {
          "name": "liberty-langserver-lemminx.jar"
        }
      }
    }
  }
}
