{
  "id": "liberty-ls",
  "name": "Liberty Config Language Server",
  "check": {
    "fileExists": {
      "name": "Check if Liberty LS is installed",
      "file": "$SERVER_HOME$/liberty-langserver.jar"
    }
  },
  "run": {
    "download": {
      "name": "Download Liberty Config Language Server",
      "url": "https://repo1.maven.org/maven2/io/openliberty/tools/liberty-langserver/2.4/liberty-langserver-2.4-jar-with-dependencies.jar",
      "output": {
        "dir": "$SERVER_HOME$",
        "file": {
          "name": "liberty-langserver.jar"
        }
      },
      "onSuccess": {
        "configureServer": {
          "name": "Configure Liberty LS command",
          "command": "java -jar $SERVER_HOME$/liberty-langserver.jar",
          "update": true
        }
      }
    }
  }
}
