{
  "id": "vscode-js-debug",
  "name": "VSCode JS Debug",
  "description": "Debug adapter for JavaScript and TypeScript",
  "launch": {
    "default": "node $SERVER_HOME$/src/dapDebugServer.js ${port} 127.0.0.1"
  },
  "debugServerReadyPattern": "DAP server listening on port ${port}",
  "documentSelector": [
    {
      "language": "javascript",
      "pattern": "**/*.{js,mjs,cjs}"
    },
    {
      "language": "typescript",
      "pattern": "**/*.{ts,tsx}"
    },
    {
      "language": "json",
      "pattern": "**/*.json"
    }
  ]
}
