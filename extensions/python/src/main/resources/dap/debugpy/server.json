{
  "id": "debugpy",
  "name": "Python - Debugpy",
  "description": "Debug adapter for Python via debugpy",
  "launch": "python -m debugpy.adapter",
  "attach": {
    "address": "$connect.host",
    "port": "$connect.port"
  },
  "documentSelector": [
    {
      "language": "python",
      "pattern": "**/*.py"
    }
  ]
}
