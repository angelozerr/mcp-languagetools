{
  "id": "debugpy",
  "name": "Python - Debugpy",
  "description": "Debug adapter for Python via debugpy",
  "launch": {
    "default": "python -m debugpy --listen 127.0.0.1:${port} --wait-for-client"
  },
  "documentSelector": [
    {
      "language": "python",
      "pattern": "**/*.py"
    }
  ]
}
