{
	"id": "java-debug",
	"name": "Java Debug Server",
	"description": "Java Debug Server for Visual Studio Code",
	"launchMethod": "vscode.java.startDebugSession",
	"documentSelector": [
		{
			"language": "java"
		}
	],
	"contributes": {
		"jdtls": {
			"bundles": [
				"extension/server/*.jar"
			],
			"bindRequest": [
				"vscode.java.validateLaunchConfig",
				"vscode.java.buildWorkspace",
				"vscode.java.resolveClasspath",
				"vscode.java.resolveJavaExecutable",
				"vscode.java.startDebugSession"
			]
		}
	}
}