{
	"id": "java-debug",
	"name": "Java Debug Server",
	"description": "Java Debug Server for Visual Studio Code",
	"launch": {
		"default": "java ???"
	},
	"documentSelector": [
		{
			"language": "java"
		}
	],
	"contributes": {
		"jdtls": {
			"bundles": [
				"plugins/*.jar"
			],
			"bindRequest": [
				"vscode.java.startDebugSession"
			]
		}
	}
}