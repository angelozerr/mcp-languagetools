{
  "id": "dart-lsp-installer",
  "name": "Dart LSP server",
  "check": {
    "exec": {
      "name": "Check if Dart SDK is available",
      "command": "dart --version",
      "timeout": 2000
    }
  },
  "run": {
    "configureServer": {
      "name": "Configure Dart LSP server command",
      "command": "dart language-server",
      "update": true
    }
  }
}
