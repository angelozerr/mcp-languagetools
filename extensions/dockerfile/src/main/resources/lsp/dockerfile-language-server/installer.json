{
  "id": "dockerfile-language-server",
  "name": "Dockerfile Language Server",
  "check": {
    "fileExists": {
      "name": "Check if dockerfile-language-server is installed",
      "file": "$SERVER_HOME$/node_modules/.bin/docker-langserver*"
    }
  },
  "run": {
    "exec": {
      "name": "Install dockerfile-language-server",
      "workingDir": "$SERVER_HOME$/node_modules",
      "command": {
        "windows": "npm.cmd install dockerfile-language-server-nodejs --force",
        "default": "npm install dockerfile-language-server-nodejs --force"
      },
      "onSuccess": {
        "configureServer": {
          "name": "Configure dockerfile-language-server command",
          "command": {
            "windows": "$SERVER_HOME$/node_modules/.bin/docker-langserver.cmd --stdio",
            "default": "$SERVER_HOME$/node_modules/.bin/docker-langserver --stdio"
          }
        }
      }
    }
  }
}
