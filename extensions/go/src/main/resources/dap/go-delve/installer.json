{
  "id": "go-delve-installer",
  "name": "go-delve",
  "check": {
    "exec": {
      "name": "Check if dlv is available",
      "command": "dlv version",
      "timeout": 2000
    }
  },
  "run": {
    "exec": {
      "name": "Install Delve",
      "command": "go install github.com/go-delve/delve/cmd/dlv@latest",
      "onSuccess": {
        "configureServer": {
          "name": "Configure go-delve server command",
          "command": "dlv dap"
        }
      }
    }
  }
}
