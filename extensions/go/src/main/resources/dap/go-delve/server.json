{
  "id": "go-delve",
  "name": "Go - Delve",
  "description": "Debug adapter for Go via Delve",
  "launch": {
    "default": "dlv dap"
  },
  "debugServerReadyPattern": "DAP server listening at: ${address}:${port}",
  "attach": {
    "port": "$port"
  },
  "documentSelector": [
    {
      "language": "go"
    }
  ]
}
