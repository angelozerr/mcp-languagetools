{
  "id": "kotlin-language-server-installer",
  "name": "kotlin-language-server",
  "check": {
    "fileExists": {
      "name": "Check if kotlin-language-server is installed",
      "file": {
        "windows": "$SERVER_HOME$/server/bin/kotlin-language-server.bat",
        "default": "$SERVER_HOME$/server/bin/kotlin-language-server"
      }
    }
  },
  "run": {
    "download": {
      "name": "Download kotlin-language-server",
      "github": {
        "owner": "fwcd",
        "repository": "kotlin-language-server",
        "prerelease": false,
        "asset": "server.zip"
      },
      "output": {
        "dir": "$SERVER_HOME$",
        "file": {
          "name": {
            "windows": "server/bin/kotlin-language-server.bat",
            "default": "server/bin/kotlin-language-server"
          },
          "executable": true
        }
      },
      "onSuccess": {
        "configureServer": {
          "name": "Configure kotlin-language-server command",
          "command": {
            "windows": "$SERVER_HOME$/server/bin/kotlin-language-server.bat",
            "default": "$SERVER_HOME$/server/bin/kotlin-language-server"
          },
          "update": true
        }
      }
    }
  }
}
