{
  "id": "omnisharp-installer",
  "name": "OmniSharp",
  "check": {
    "fileExists": {
      "name": "Check if OmniSharp is installed",
      "file": {
        "windows": "$SERVER_HOME$/OmniSharp.exe",
        "default": "$SERVER_HOME$/OmniSharp"
      }
    }
  },
  "run": {
    "download": {
      "name": "Download OmniSharp",
      "github": {
        "owner": "OmniSharp",
        "repository": "omnisharp-roslyn",
        "prerelease": false,
        "asset": {
          "windows": {
            "x86_64": "omnisharp-win-x64-net6.0.zip",
            "arm64": "omnisharp-win-arm64-net6.0.zip"
          },
          "unix": {
            "x86_64": "omnisharp-linux-x64-net6.0.tar.gz",
            "arm64": "omnisharp-linux-arm64-net6.0.tar.gz"
          },
          "mac": {
            "x86_64": "omnisharp-osx-x64-net6.0.tar.gz",
            "arm64": "omnisharp-osx-arm64-net6.0.tar.gz"
          }
        }
      },
      "output": {
        "dir": "$SERVER_HOME$",
        "file": {
          "name": {
            "windows": "OmniSharp.exe",
            "default": "OmniSharp"
          },
          "executable": true
        }
      },
      "onSuccess": {
        "configureServer": {
          "name": "Configure OmniSharp server command",
          "command": {
            "windows": "$SERVER_HOME$/OmniSharp.exe -lsp",
            "default": "$SERVER_HOME$/OmniSharp -lsp"
          }
        }
      }
    }
  }
}
