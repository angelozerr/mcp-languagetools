{
	"id": "qute",
	"name": "Qute Language Server",
	"check": {
		"fileExists": {
			"name": "Check if Qute is installed",
			"file": "$SERVER_HOME$/lib/com.redhat.qute.ls-uber.jar"
		}
	},
	"run": {
		"download": {
			"name": "Download Qute LS uber JAR",
			"github": {
				"owner": "redhat-developer",
				"repository": "quarkus-ls",
				"prerelease": false,
				"asset": "com.redhat.qute.ls-uber.jar"
			},
			"output": {
				"dir": "$SERVER_HOME$/lib",
				"file": { "name": "com.redhat.qute.ls-uber.jar" }
			},
			"onSuccess": {
				"download": {
					"name": "Download Qute JDT plugin",
					"github": {
						"owner": "redhat-developer",
						"repository": "quarkus-ls",
						"prerelease": false,
						"asset": "com.redhat.qute.jdt_*.jar"
					},
					"output": {
						"dir": "$SERVER_HOME$/plugins",
						"file": { "name": "com.redhat.qute.jdt.jar" }
					},
					"onSuccess": {
						"configureServer": {
							"name": "Configure Qute server command",
							"command": "java -jar \"$SERVER_HOME$/lib/com.redhat.qute.ls-uber.jar\""
						}
					}
				}
			}
		}
	}
}