{
  "id": "mcp-jdtls",
  "name": "MCP JDT.LS Extensions",
  "description": "Advanced Java analysis commands via JDT.LS delegate command handlers",
  "documentSelector": [
    {
      "language": "java"
    }
  ],
  "contributes": {
    "jdtls": {
      "bundles": ["plugins/*.jar"],
      "diagnostics": "mcp.jdtls.diagnostics",
      "bindRequest": [
        "mcp.jdtls.diagnostics",
        "mcp.jdtls.typeHierarchy",
        "mcp.jdtls.callHierarchyIncoming",
        "mcp.jdtls.callHierarchyOutgoing",
        "mcp.jdtls.findAnnotationUsages",
        "mcp.jdtls.findTypeInstantiations",
        "mcp.jdtls.getComplexityMetrics",
        "mcp.jdtls.findCasts",
        "mcp.jdtls.findCatchBlocks",
        "mcp.jdtls.findInstanceofChecks",
        "mcp.jdtls.findThrowsDeclarations",
        "mcp.jdtls.findTypeArguments",
        "mcp.jdtls.findMethodReferences",
        "mcp.jdtls.findFieldWrites",
        "mcp.jdtls.findTests",
        "mcp.jdtls.findAffectedTests",
        "mcp.jdtls.findUnusedCode",
        "mcp.jdtls.findUnreachableCode",
        "mcp.jdtls.findReflectionUsage",
        "mcp.jdtls.suggestImports",
        "mcp.jdtls.getTypeUsageSummary",
        "mcp.jdtls.searchSymbols",
        "mcp.jdtls.findReferences",
        "mcp.jdtls.findImplementations",
        "mcp.jdtls.goToDefinition",
        "mcp.jdtls.getHoverInfo",
        "mcp.jdtls.getJavadoc",
        "mcp.jdtls.getSymbolInfo",
        "mcp.jdtls.getEnclosingElement",
        "mcp.jdtls.getFieldAtPosition",
        "mcp.jdtls.getMethodAtPosition",
        "mcp.jdtls.getTypeAtPosition",
        "mcp.jdtls.getSignatureHelp",
        "mcp.jdtls.getSuperMethod",
        "mcp.jdtls.getDocumentSymbols",
        "mcp.jdtls.getTypeMembers",
        "mcp.jdtls.getDependencyGraph",
        "mcp.jdtls.analyzeChangeImpact",
        "mcp.jdtls.analyzeControlFlow",
        "mcp.jdtls.analyzeDataFlow",
        "mcp.jdtls.analyzeFile",
        "mcp.jdtls.analyzeMethod",
        "mcp.jdtls.analyzeType",
        "mcp.jdtls.findLargeClasses",
        "mcp.jdtls.findNamingViolations",
        "mcp.jdtls.findPossibleBugs",
        "mcp.jdtls.findCircularDependencies",
        "mcp.jdtls.validateSyntax",
        "mcp.jdtls.getQuickFixes",
        "mcp.jdtls.applyQuickFix",
        "mcp.jdtls.diagnoseAndFix",
        "mcp.jdtls.applyCleanup",
        "mcp.jdtls.getHttpEndpoints",
        "mcp.jdtls.getJpaModel",
        "mcp.jdtls.getDiRegistrations",
        "mcp.jdtls.renameSymbol",
        "mcp.jdtls.organizeImports",
        "mcp.jdtls.extractMethod",
        "mcp.jdtls.extractVariable",
        "mcp.jdtls.extractConstant",
        "mcp.jdtls.extractInterface",
        "mcp.jdtls.extractSuperclass",
        "mcp.jdtls.inlineMethod",
        "mcp.jdtls.inlineVariable",
        "mcp.jdtls.changeMethodSignature",
        "mcp.jdtls.convertAnonymousToLambda",
        "mcp.jdtls.encapsulateField",
        "mcp.jdtls.introduceParameterObject",
        "mcp.jdtls.moveTypeToNewFile",
        "mcp.jdtls.pullUp",
        "mcp.jdtls.pushDown",
        "mcp.jdtls.getProjectStructure",
        "mcp.jdtls.getClasspathInfo"
      ]
    }
  }
}
